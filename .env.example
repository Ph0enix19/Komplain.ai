# LLM provider selection: 'zai' (primary), 'groq', or legacy 'ilmu'
LLM_PROVIDER=zai

# Z.ai / GLM primary provider
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-5.1
ZAI_TIMEOUT=60
ZAI_THINKING_TYPE=disabled
ZAI_TEMPERATURE=0.1
ZAI_VISION_BASE_URL=https://api.z.ai/api/coding/paas/v4
ZAI_VISION_MODEL=glm-4.5v
ZAI_VISION_THINKING_TYPE=disabled
VISION_ENABLED=true

# Fallback provider
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=180

# Legacy GLM-oriented ILMU provider
ILMU_API_KEY=
ILMU_BASE_URL=https://api.ilmu.ai/v1
ILMU_MODEL=your_legacy_ilmu_model_here
ILMU_REASONING_EFFORT=low
