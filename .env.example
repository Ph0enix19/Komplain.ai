# LLM Provider selection: 'groq' (default) or 'ilmu'
LLM_PROVIDER=groq

# ILMU GLM-5.1 (primary)
ILMU_API_KEY=
ILMU_BASE_URL=https://api.ilmu.ai/v1
ILMU_MODEL=ilmu-glm-5.1
ILMU_REASONING_EFFORT=low

# Groq (free-tier-friendly OpenAI-compatible provider)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=180
