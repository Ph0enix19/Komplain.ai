# LLM Provider selection: 'ilmu' (default), 'gemini', or 'groq'
LLM_PROVIDER=groq

# ILMU GLM-5.1 (primary)
ILMU_API_KEY=
ILMU_BASE_URL=https://api.ilmu.ai/v1
ILMU_MODEL=ilmu-glm-5.1
ILMU_REASONING_EFFORT=low

# Google Gemini (failover)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash-lite

# Groq (free-tier-friendly OpenAI-compatible provider)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
